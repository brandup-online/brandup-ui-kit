{
	"compilerOptions": {
		"module": "node16",
		"moduleResolution": "node16",
		"target": "ES2022",
		"outDir": "./server",
		"rootDir": "./src/backend",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"forceConsistentCasingInFileNames": true,
		"sourceMap": false
	},
	"include": ["src/backend/**/*"]
}
