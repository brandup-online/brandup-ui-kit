{
	"version": "1.0.0",
	"name": "brandup-ui-example",
	"private": true,
	"dependencies": {
		"@brandup/ui": "^2.0.3",
		"@brandup/ui-ajax": "^2.0.3",
		"@brandup/ui-app": "^2.0.3",
		"@brandup/ui-dropdown": "file:../brandup-ui-dropdown",
		"@brandup/ui-helpers": "^2.0.3",
		"@brandup/ui-kit": "file:../brandup-ui-kit",
		"@brandup/ui-textbox": "file:../brandup-ui-textbox",
		"cors": "^2.8.6",
		"express": "^5.2.1"
	},
	"devDependencies": {
		"@babel/plugin-transform-runtime": "^7.29.7",
		"@babel/preset-env": "^7.29.7",
		"@babel/preset-typescript": "^7.29.7",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.9.1",
		"babel-loader": "^10.1.1",
		"cross-env": "^10.1.0",
		"css-loader": "^7.1.4",
		"css-select": "^7.0.0",
		"file-loader": "^6.2.0",
		"html-webpack-plugin": "^5.6.7",
		"less": "^4.6.4",
		"less-loader": "^13.0.0",
		"less-plugin-clean-css": "^1.6.0",
		"mini-css-extract-plugin": "^2.10.2",
		"raw-loader": "^4.0.2",
		"selfsigned": "^5.5.0",
		"style-loader": "^4.0.0",
		"svgo": "^4.0.1",
		"svgo-loader": "^5.0.0",
		"terser-webpack-plugin": "^5.6.1",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3",
		"url-loader": "^4.1.1",
		"webpack": "^5.107.2",
		"webpack-cli": "^7.0.3",
		"webpack-dev-server": "^5.2.4"
	},
	"scripts": {
		"setup-cert": "node ./scripts/generate-cert.cjs",
		"build": "tsc -p tsconfig.backend.json && cross-env NODE_ENV=production webpack --config webpack.config.js",
		"dev-build": "cross-env NODE_ENV=development webpack --config webpack.config.js",
		"watch": "cross-env NODE_ENV=development webpack --config webpack.config.js --watch",
		"dev-server": "cross-env NODE_ENV=development webpack serve --config webpack.config.js",
		"prestart": "npm run setup-cert",
		"start": "node ./server/program.js --port=8316",
		"serve": "npm run build && npm run start"
	}
}
