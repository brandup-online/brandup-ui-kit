{
	"version": "1.0.0",
	"name": "brandup-ui-kit-root",
	"private": true,
	"devDependencies": {
		"@babel/core": "^7.29.7",
		"@babel/plugin-transform-runtime": "^7.29.7",
		"@babel/preset-env": "^7.29.7",
		"@babel/preset-typescript": "^7.29.7",
		"@babel/runtime": "^7.29.7",
		"@brandup/autonpm": "^1.0.21",
		"@eslint/js": "^10.0.1",
		"@types/jest": "^30.0.0",
		"babel-jest": "^30.4.1",
		"cross-env": "^10.1.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.6.0",
		"jest": "^30.4.2",
		"jest-clipboard": "^0.0.11-beta.1",
		"jest-environment-jsdom": "^30.4.1",
		"jest-transform-stub": "^2.0.0",
		"prettier": "^3.8.3",
		"ts-node": "^10.9.2",
		"typescript-eslint": "^8.60.1"
	},
	"scripts": {
		"i": "npm i && npm run npm:install",
		"u": "npm update --save && npm run npm:update",
		"build": "npm run npm:build",
		"watch": "npm run npm:watch",
		"npm:install": "autonpm install",
		"npm:update": "autonpm update -save",
		"npm:build": "autonpm build",
		"npm:watch": "autonpm watch",
		"npm:version": "autonpm-version",
		"npm:cleanup": "autonpm-cleanup",
		"npm:pack": "autonpm pack",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "cross-env NODE_ENV=test jest --config=jest.config.ts --no-cache --passWithNoTests"
	}
}
